{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "token-usage-app",
  "version": "1.0.7",
  "identifier": "com.bv-leedonghoon.token-usage-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "token-usage-app",
        "width": 800,
        "height": 600,
        "minWidth": 700,
        "minHeight": 480
      },
      {
        "label": "widget",
        "url": "widget.html",
        "title": "Widget",
        "width": 260,
        "height": 300,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https://raw.githubusercontent.com"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/donghoon-bigvalue/token-usage-app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIyQjk5QzcxRkJFOEE2MjgKUldRb3B1ajdjWnk1SXAwMUs4RVk1YklPbkFyUlQzY21sTFVLWGtSQW91akp6aGdYdUhYOThVV08K"
    }
  }
}
